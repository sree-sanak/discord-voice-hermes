# Discord bot token. Create at https://discord.com/developers/applications
DISCORD_VOICE_BOT_TOKEN=

# OpenAI API key used only for speech-to-text and text-to-speech.
# The assistant brain can use Hermes/Codex OAuth separately.
VOICE_TOOLS_OPENAI_KEY=

# Optional: comma-separated Discord user IDs allowed to trigger/listen.
# Leave empty to allow anyone in servers where the bot is installed.
DISCORD_VOICE_ALLOWED_USERS=

# Optional command/config defaults.
VOICE_COMMAND_PREFIX=!voice
VOICE_STT_MODEL=gpt-4o-mini-transcribe
VOICE_TTS_MODEL=gpt-4o-mini-tts
VOICE_TTS_VOICE=alloy
VOICE_FAST_MODE=true
VOICE_MIN_AUDIO_MS=200
VOICE_END_SILENCE_MS=275
VOICE_IGNORE_AFTER_PLAYBACK_MS=1200
VOICE_DAVE_ENCRYPTION=false
VOICE_DEBUG=false
VOICE_DECRYPTION_FAILURE_TOLERANCE=1000
VOICE_JOIN_ATTEMPTS=3
VOICE_AUTO_FOLLOW=true
VOICE_AUTO_TEXT_CONTEXT=true
VOICE_DEFAULT_CHANNEL_NAME=voice-chat
VOICE_TEXT_CONTEXT_FETCH_LIMIT=30
VOICE_TEXT_CONTEXT_MAX_MESSAGES=8
VOICE_TEXT_CONTEXT_MAX_AGE_MS=21600000

# Assistant backend. "openai" is fastest for voice chat; "hermes" uses `hermes chat`; "codex" uses `codex exec` directly.
VOICE_RESPONSE_BACKEND=hermes
VOICE_OPENAI_MODEL=gpt-4o-mini
VOICE_HERMES_BIN=hermes
VOICE_HERMES_PROVIDER=openai-codex
VOICE_HERMES_MODEL=gpt-5.5
VOICE_HERMES_TIMEOUT_MS=15000
VOICE_HERMES_TOOLSETS=

# Used only when VOICE_RESPONSE_BACKEND=codex.
VOICE_CODEX_BIN=codex
VOICE_CODEX_HOME=/var/lib/hermes-codex
VOICE_CODEX_MODEL=gpt-5.5
VOICE_CODEX_TIMEOUT_MS=60000
